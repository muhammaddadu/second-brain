{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    // BlockNote's generic editor types aren't written for exactOptionalPropertyTypes; relax it
    // for the renderer only. packages/core keeps the full-strict base config.
    "exactOptionalPropertyTypes": false,
    "noEmit": true
  },
  "include": ["src/renderer", "src/shared"]
}
