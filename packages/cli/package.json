{
  "name": "@brain/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "brain": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude '**/*.e2e.test.ts'",
    "test:e2e": "tsc -p tsconfig.build.json && vitest run src/cli.e2e.test.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@brain/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
